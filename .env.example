# Twitch stream key — get yours from https://dashboard.twitch.tv/settings/stream
TWITCH_STREAM_KEY=live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional Twitch Helix API creds: used by the stream container on startup (see stream/entrypoint.sh)
# to PATCH channel title/category when TWITCH_AUTO_SET_TITLE is true. If any of these three are empty,
# that step is skipped (set TWITCH_AUTO_SET_TITLE=false to disable the attempt entirely).
TWITCH_CLIENT_ID=
TWITCH_OAUTH_TOKEN=
TWITCH_BROADCASTER_ID=
# Auto-update Twitch title when stream container starts (true/false)
TWITCH_AUTO_SET_TITLE=true
# Pokémon Showdown category on Twitch (https://www.twitch.tv/directory/category/pokemon-showdown)
TWITCH_GAME_ID=850490686
# Title sent when auto-updating Twitch metadata (stream entrypoint)
TWITCH_STREAM_TITLE=Pokémon Showdown battles with LLMs

# Anthropic API key — get yours from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DeepSeek API key — get yours from https://platform.deepseek.com/
DEEPSEEK_API_KEY=
# Optional DeepSeek base URL
DEEPSEEK_BASE_URL=https://api.deepseek.com
# OpenRouter API key — get yours from https://openrouter.ai/keys
# Gives access to hundreds of models (Llama, Gemini, Mistral, Qwen, etc.)
OPENROUTER_API_KEY=
# Optional OpenRouter base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OpenRouter extra_body: https://openrouter.ai/docs/guides/best-practices/reasoning-tokens
# Base JSON merged into every OpenRouter request:
# OPENROUTER_DEFAULT_EXTRA_BODY_JSON={"reasoning":{"effort":"none"}}
# Per-model shallow merge over default (keys = OpenRouter model id, case-insensitive):
# OPENROUTER_EXTRA_BODY_BY_MODEL_JSON={"google/gemini-2.5-flash-lite":{"reasoning":{"max_tokens":768}}}
# Do not set both reasoning.effort and reasoning.max_tokens in one merged body (docs: one or the other).
# OpenRouter: auto = use json_schema if model is listed for structured_outputs; force | off
OPENROUTER_STRUCTURED_OUTPUTS=auto

# Provider, model, and persona per side come from the Manager, create_match.sh, or
# create_tournament.sh. Personas are markdown files in agents/personas/*.md (see /manager/personas).

# Directory where agents export local replay HTML files
REPLAY_DIR=/replays

# Directory where agents export raw battle logs (JSON)
LOG_DIR=/logs
# Toggle raw log export (true/false)
LOG_RAW_BATTLE=true
# Shared state directory for current live battle metadata
STATE_DIR=/state

# Slow down decisions for watchability (seconds per turn per player)
TURN_DELAY_SECONDS=3
# Max model output tokens per turn — Anthropic, DeepSeek, and OpenRouter (default 512)
LLM_MAX_OUTPUT_TOKENS=512
# Hard timeout per LLM turn in seconds — if an API call hangs longer than this,
# the player falls back to a random move so the battle keeps going (default 150)
LLM_TURN_TIMEOUT=150
# Pause between completed matches (seconds)
DELAY_BETWEEN_MATCHES=15
# Seconds between polls when the manager queue is empty (queue worker only)
QUEUE_POLL_INTERVAL=5
# Tournament-only: seconds to hold the opener before the first match starts (0 = off)
TOURNAMENT_INTRO_SECONDS=15
# Seconds to delay after the tournament intro hold (fade + margin before match intro). 0 = no delay phase.
TOURNAMENT_INTRO_DELAY_SECONDS=5
# Agents: keep status=starting before battle connects (~0.45s so /broadcast can show match intro). 0 = no hold.
MATCH_INTRO_STARTING_HOLD_SECONDS=0.45

# Pokedex tool: let Anthropic models look up move/ability/item/type details mid-turn (true/false)
POKEDEX_TOOL_ENABLED=false
# Auto-enrich: inject Pokedex notes into battle context for all providers (true/false)
POKEDEX_AUTO_ENRICH=false
# Max Pokedex tool calls per turn before forcing an action (default 3)
POKEDEX_MAX_LOOKUPS=3

# Persona adaptive memory: episodic memory.md + tactical learnings.md under STATE_DIR/personas/{slug}/ (true/false)
ENABLE_MEMORY=false
# Run post-match reflection every N completed matches per persona (0 = never)
MEMORY_REFLECTION_INTERVAL=1
# When reflection runs, refresh learnings.md every N matches per persona (0 = never update learnings)
LEARNINGS_UPDATE_INTERVAL=3
# Cap how many "## Match ..." blocks are kept in memory.md
MAX_MEMORY_ENTRIES=10
# Cap bullet points when trimming learnings.md after an update
MAX_LEARNINGS_BULLETS=30
# Max completion tokens for the post-match reflection LLM call
LLM_MEMORY_REFLECTION_MAX_TOKENS=2048

# Stream browser source page (used by stream container)
STREAM_VIEW_URL=http://web:8080/broadcast
# Title on the broadcast page (shown on stream)
STREAM_TITLE=Pokémon Showdown battles with LLMs
# Stream audio source: browser | pulse
STREAM_AUDIO_SOURCE=pulse

# Showdown server (internal Docker network)
SHOWDOWN_HOST=showdown
SHOWDOWN_PORT=8000
# URL your browser uses for the Showdown client (manager “Open battle” links). Example: https://localhost.psim.us
SHOWDOWN_VIEW_BASE=http://localhost:8000
# Web image bundles Showdown for POST /api/manager/teams/validate-showdown (team import form).
# TEAM_VALIDATION_DISABLED=true skips that check. Override SHOWDOWN_HOME only for custom layouts.
# SHOWDOWN_HOME=/opt/pokemon-showdown
# TEAM_VALIDATION_DISABLED=false

# Web service (scoreboard, broadcast, manager, API). Deprecated: OVERLAY_HOST / OVERLAY_PORT still work in agents/stream.
WEB_HOST=web
WEB_PORT=8080
# Web only: WEB_DEBUG=true adds INFO diagnostics (scoreboard SSE publishes, etc.); see web_debug.py
WEB_DEBUG=false

# Victory splash visible duration on /broadcast (seconds; fade-out adds ~0.5s)
VICTORY_MODAL_SECONDS=25
# Same splash when the match clinches the tournament (victory_tournament_clinched); longer default for finales
TOURNAMENT_VICTORY_MODAL_SECONDS=60
# Delay after a win is tallied before the splash appears (seconds; 0 = immediate)
VICTORY_SHOW_DELAY_SECONDS=5
# After status goes idle, wait this long before resetting the Showdown iframe to the lobby
# (seconds; 0 = old behavior). Gives time for in-client win text and animations.
BATTLE_IFRAME_OUTRO_SECONDS=30
# Matchup card on /broadcast when agents connect (status starting); 0 disables
MATCH_INTRO_SECONDS=7
# After victory, bracket/up-next interstitial duration (seconds; 0 = off). Web only shows it in tournaments
# (scoreboard has tournament_id) when /api/manager/queue/upcoming has at least one row.
BRACKET_INTERSTITIAL_SECONDS=25

# Hide native Showdown battle UI in stream/embed views (true/false)
HIDE_BATTLE_UI=true

# docker-compose mounts this file into the web container as /app/host.env with MANAGER_HOST_ENV_FILE so
# http://localhost:8080/manager/config can view/edit keys listed in web/manager/env_registry.py
