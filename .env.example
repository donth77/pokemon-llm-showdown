# Twitch stream key — get yours from https://dashboard.twitch.tv/settings/stream
TWITCH_STREAM_KEY=live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional Twitch API creds for scripts/set_twitch_title.sh
TWITCH_CLIENT_ID=
TWITCH_OAUTH_TOKEN=
TWITCH_BROADCASTER_ID=
# Auto-update Twitch title when stream container starts (1/0)
TWITCH_AUTO_SET_TITLE=1
# Pokémon category on Twitch (default)
TWITCH_GAME_ID=1982936547
# Optional title override for scripts/set_twitch_title.sh
TWITCH_STREAM_TITLE=Pokémon Showdown battles with LLMs

# Anthropic API key — get yours from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DeepSeek API key — get yours from https://platform.deepseek.com/
DEEPSEEK_API_KEY=
# Optional DeepSeek base URL
DEEPSEEK_BASE_URL=https://api.deepseek.com
# OpenRouter API key — get yours from https://openrouter.ai/keys
# Gives access to hundreds of models (Llama, Gemini, Mistral, Qwen, etc.)
OPENROUTER_API_KEY=
# Optional OpenRouter base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional JSON merged into chat requests (OpenRouter-only). Example for GLM “thinking” models:
# OPENROUTER_EXTRA_BODY_JSON={"reasoning":{"enabled":false}}
# OpenRouter: auto = use json_schema if model is listed for structured_outputs; force | off
OPENROUTER_STRUCTURED_OUTPUTS=auto

# Per-player provider/model overrides (required for matchups).
# Persona is configurable per player via PLAYER1_PERSONA / PLAYER2_PERSONA.
# Valid providers: anthropic, deepseek, openrouter
# For openrouter, use the full model path (e.g. google/gemini-2.0-flash).
PLAYER1_PROVIDER=deepseek
PLAYER1_MODEL=deepseek-chat
PLAYER2_PROVIDER=anthropic
PLAYER2_MODEL=claude-haiku-4-5-20251001
# Available personas live in agents/personas/*.md (default: aggro, stall).
PLAYER1_PERSONA=aggro
PLAYER2_PERSONA=stall

# Directory where agents export local replay HTML files
REPLAY_DIR=/replays

# Directory where agents export raw battle logs (JSON)
LOG_DIR=/logs
# Toggle raw log export (1/0)
LOG_RAW_BATTLE=1
# Shared state directory for current live battle metadata
STATE_DIR=/state

# Slow down decisions for watchability (seconds per turn per player)
TURN_DELAY_SECONDS=0
# Max model output tokens per turn, all providers (default 512)
LLM_MAX_OUTPUT_TOKENS=512
# Hard timeout per LLM turn in seconds — if an API call hangs longer than this,
# the player falls back to a random move so the battle keeps going (default 150)
LLM_TURN_TIMEOUT=150
# Pause between completed matches (seconds)
DELAY_BETWEEN_MATCHES=15

# Matches before exit: N>=1 runs N battles; 0 = keep playing until the container stops (best for streams)
MATCH_COUNT=100
# Randomly pick one format per match from this comma-separated pool
BATTLE_FORMAT_POOL=gen8randombattle,gen9randombattle

# Stream browser source page (used by stream container)
STREAM_VIEW_URL=http://overlay:8080/broadcast
# Broadcast overlay title shown on stream
STREAM_TITLE=Pokémon Showdown battles with LLMs
# Stream audio source: browser | music | pulse
STREAM_AUDIO_SOURCE=pulse
# Optional: FFmpeg audio input for looping battle music (local path or URL)
BATTLE_MUSIC_INPUT=

# Showdown server (internal Docker network)
SHOWDOWN_HOST=showdown
SHOWDOWN_PORT=8000

# Overlay service
OVERLAY_HOST=overlay
OVERLAY_PORT=8080
# Victory splash visible duration on /broadcast (seconds; fade-out adds ~0.5s)
VICTORY_MODAL_SECONDS=30
